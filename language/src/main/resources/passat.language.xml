<!-- Object Pascal language core content module descriptor.
     This descriptor belongs to the reusable :language content module (jar: passat.language.jar).
     Register parsing and PSI-level IDE features here: fileType, lang.parserDefinition,
     lang.syntaxHighlighterFactory, lang.braceMatcher, lang.foldingBuilder, lang.commenter,
     lang.psiStructureViewFactory, completion.contributor, psi.referenceContributor,
     lang.findUsagesProvider, annotator, localInspection, etc. -->
<idea-plugin>
    <!-- Extension point a toolchain-aware host (e.g. :plugin) fills to supply a unit's real internal
         name (read from a compiled .ppu) instead of its file-name-derived default. -->
    <extensionPoints>
        <extensionPoint
            qualifiedName="org.pcsoft.passat.language.unitNameProvider"
            interface="org.pcsoft.passat.language.psi.PascalUnitNameProvider"
            dynamic="true"/>
    </extensionPoints>

    <extensions defaultExtensionNs="com.intellij">
        <fileType
            name="Object Pascal"
            language="ObjectPascal"
            extensions="pas;pp;lpr"
            implementationClass="org.pcsoft.passat.language.ObjectPascalFileType"
            fieldName="INSTANCE"/>
        <lang.parserDefinition
            language="ObjectPascal"
            implementationClass="org.pcsoft.passat.language.parser.ObjectPascalParserDefinition"/>
        <lang.syntaxHighlighterFactory
            language="ObjectPascal"
            implementationClass="org.pcsoft.passat.language.highlight.ObjectPascalSyntaxHighlighterFactory"/>
        <lang.foldingBuilder
            language="ObjectPascal"
            implementationClass="org.pcsoft.passat.language.folding.ObjectPascalFoldingBuilder"/>
        <completion.contributor
            language="ObjectPascal"
            implementationClass="org.pcsoft.passat.language.completion.ObjectPascalUsesCompletionContributor"/>
        <completion.contributor
            language="ObjectPascal"
            implementationClass="org.pcsoft.passat.language.completion.ObjectPascalKeywordCompletionContributor"/>
        <annotator
            language="ObjectPascal"
            implementationClass="org.pcsoft.passat.language.annotator.ObjectPascalUnresolvedUnitAnnotator"/>
        <annotator
            language="ObjectPascal"
            implementationClass="org.pcsoft.passat.language.annotator.ObjectPascalMissingDefinitionAnnotator"/>
        <intentionAction>
            <language>ObjectPascal</language>
            <className>org.pcsoft.passat.language.intention.CreateProgramSkeletonFix</className>
            <category>Object Pascal</category>
        </intentionAction>
        <intentionAction>
            <language>ObjectPascal</language>
            <className>org.pcsoft.passat.language.intention.CreateUnitSkeletonFix</className>
            <category>Object Pascal</category>
        </intentionAction>
    </extensions>
</idea-plugin>
