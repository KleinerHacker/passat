/*
 * Object Pascal grammar (Grammar-Kit).
 *
 * Phase 1, first step: only a complete but empty program is accepted:
 *
 *     program Demo;
 *     begin
 *     end.
 *
 * The grammar grows as language support expands (see PASCAL_STATUS.md). Object Pascal is
 * case-insensitive; the case-insensitive matching of keywords is handled by the JFlex lexer
 * (ObjectPascal.flex), so this grammar only references the abstract token types.
 */
{
  parserClass="org.pcsoft.passat.language.parser.ObjectPascalParser"

  extends="com.intellij.extapi.psi.ASTWrapperPsiElement"

  psiClassPrefix="ObjectPascal"
  psiImplClassSuffix="Impl"
  psiPackage="org.pcsoft.passat.language.parser.psi"
  psiImplPackage="org.pcsoft.passat.language.parser.psi.impl"

  elementTypeHolderClass="org.pcsoft.passat.language.parser.psi.ObjectPascalTypes"
  elementTypeClass="org.pcsoft.passat.language.psi.ObjectPascalElementType"
  tokenTypeClass="org.pcsoft.passat.language.psi.ObjectPascalTokenType"

  tokens=[
    PROGRAM="program"
    UNIT="unit"
    USES="uses"
    INTERFACE="interface"
    IMPLEMENTATION="implementation"
    IN="in"
    BEGIN="begin"
    END="end"
    SEMICOLON=";"
    COMMA=","
    DOT="."
  ]
}

pascalFile ::= programDefinition | unitDefinition

programDefinition ::= PROGRAM IDENTIFIER SEMICOLON usesClause? block DOT

// A unit file: header, interface section (may import units), implementation section
// (may import units), terminated by `end.`. Initialization blocks are future work.
unitDefinition ::= UNIT IDENTIFIER SEMICOLON INTERFACE usesClause? IMPLEMENTATION usesClause? END DOT

usesClause ::= USES unitReference (COMMA unitReference)* SEMICOLON

// A single imported unit, optionally with an explicit source file (`unit in 'file.pas'`).
// Carries the reference that resolves the unit name to its declaring file.
unitReference ::= IDENTIFIER (IN STRING)? {
  mixin="org.pcsoft.passat.language.psi.impl.ObjectPascalUnitReferenceMixin"
  implements="org.pcsoft.passat.language.psi.ObjectPascalUsedUnit"
  methods=[getReference getUnitName getNameIdentifier]
}

block ::= BEGIN END
