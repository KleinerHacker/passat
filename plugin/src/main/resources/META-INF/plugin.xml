<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin url="https://github.com/KleinerHacker/passat">
    <!-- Unique identifier of the plugin. It should be FQN. It cannot be changed between the plugin versions. -->
    <id>org.pcsoft.ij.plugin.passat</id>

    <!-- Public plugin name should be written in Title Case.
     Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-name -->
    <name>Passat</name>

    <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
    <vendor>PC SOFT</vendor>

    <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-description -->
    <description><![CDATA[
        Object Pascal support for JetBrains IDEs, built on a free Object Pascal compiler (FPC).<br>
        Provides a dedicated Pascal project/module type with a target compiler, target language
        version and dependency list, full language tooling, build &amp; run and debugging.
        ]]></description>

    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.platform</depends>

    <!-- The reusable Object Pascal language core (:language) is bundled as a content module.
         Its descriptor (passat.language.xml) registers all parsing and PSI-level IDE features. -->
    <content>
        <module name="passat.language"/>
    </content>

    <!-- Extensions defined by the plugin (project/module model, toolchain, run/build/debug).
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensions defaultExtensionNs="com.intellij">
        <!-- FPC compiler registered as a first-class SDK (the JDK analogy for Pascal). -->
        <sdkType implementation="org.pcsoft.passat.plugin.sdk.FpcSdkType"/>

        <!-- Dedicated Pascal module type and its new-module builder. -->
        <moduleType id="PASCAL_MODULE"
                    implementationClass="org.pcsoft.passat.plugin.module.PascalModuleType"/>
        <moduleBuilder builderClass="org.pcsoft.passat.plugin.module.PascalModuleBuilder"/>

        <!-- "Pascal" template selectable in the New Project wizard. -->
        <newProjectWizard.generator implementation="org.pcsoft.passat.plugin.wizard.PascalNewProjectWizard"/>

        <!-- Adds the "Pascal" tab in Project Structure; Sources/Dependencies come from the platform. -->
        <moduleConfigurationEditorProvider
            implementation="org.pcsoft.passat.plugin.module.PascalModuleConfigurationEditorProvider"/>

        <!-- Templates backing the "New Object Pascal File" action (resources/fileTemplates/internal). -->
        <internalFileTemplate name="Pascal Unit"/>
        <internalFileTemplate name="Pascal Program"/>
    </extensions>

    <!-- Supplies compiled units' real internal names (read from .ppu via ppudump) to the language
         core's unit-name extension point. -->
    <extensions defaultExtensionNs="org.pcsoft.passat.language">
        <unitNameProvider implementation="org.pcsoft.passat.plugin.sdk.ppu.FpcPpuUnitNameProvider"/>
    </extensions>

    <!-- "New > Object Pascal File" entry in the project-view / file context New menu. -->
    <actions>
        <action id="Passat.NewPascalFile"
                class="org.pcsoft.passat.plugin.action.CreatePascalFileAction">
            <add-to-group group-id="NewGroup" anchor="before" relative-to-action="NewFile"/>
        </action>
    </actions>

</idea-plugin>
